# Copy to .env (not committed). Server-side only — never VITE_* for NVIDIA keys.
# Jobs submitted with dryRun: true are stubs only — they do not call NVIDIA and do not use the API key path.

# Optional: Umami analytics (injected into index.html in dev/build only when both are set)
# VITE_ANALYTICS_ENDPOINT=https://analytics.example.com
# VITE_ANALYTICS_WEBSITE_ID=

# NVIDIA Healthcare (server only; used by Express api-dev + production server)
NVIDIA_HEALTHCARE_API_KEY=
# --- Profiles (same `/biology/...` paths; only the host + /v1 prefix changes) ---
# Default (Healthcare NIM examples):
#   NVIDIA_HEALTHCARE_BASE_URL=https://health.api.nvidia.com/v1
# Alternative gateway (if your key is provisioned there):
#   NVIDIA_HEALTHCARE_BASE_URL=https://integrate.api.nvidia.com/v1
# Path env overrides (`NVIDIA_AF3_PATH`, …) stay relative to that base, e.g. `/biology/openfold/openfold3/predict`.

# Long-poll header for NVIDIA Cloud Functions (matches curl examples; set to 0 to disable)
# NVIDIA_NVCF_POLL_SECONDS=300

# Path overrides (optional). Defaults live in server/core/config/nvidiaEndpoints.ts (`NVIDIA_ENDPOINTS` + resolveNvidiaPathsFromEnv).
# Spec: https://docs.api.nvidia.com/nim/reference/healthcare-apis
# NVIDIA_AF3_PATH=/biology/openfold/openfold3/predict
# NVIDIA_MSA_PATH=/biology/colabfold/msa-search/predict
# NVIDIA_EVO2_PATH=/biology/arc/evo2-40b/generate
# NVIDIA_BOLTZ2_PATH=/biology/mit/boltz2/predict
# NVIDIA_GENMOL_PATH=/biology/nvidia/genmol/generate

# Async inference: when POST returns 202 or pending status + provider job id, poll GET until terminal.
# Required for tenants that do not return the final JSON on the initial POST. Placeholders: {jobId}, {service}.
# NVIDIA_JOB_STATUS_PATH_TEMPLATE=/v1/healthcare/jobs/{jobId}
# NVIDIA_POLL_MAX_ATTEMPTS=80
# NVIDIA_POLL_INTERVAL_MS=2500

# Job JSON persistence directory (relative to repo root)
# BIOLABS_JOB_DATA_DIR=data/jobs

# Log one JSON line per AI job create when set to 1
# BIOLABS_LOG_AI_USAGE=1

# Dev: `pnpm dev` serves /api/ai inside Vite. Use `pnpm dev:api` for standalone BFF on this port.
# BIOLABS_API_PORT=3001
